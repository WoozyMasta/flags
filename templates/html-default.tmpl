<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ quoteHTML .Doc.Name }} CLI Documentation</title>
</head>
<body>
  <h1>{{ quoteHTML .Doc.Name }}</h1>

  <section>
    <h2>Synopsis</h2>
    <pre>{{ quoteHTML .Doc.Name }} {{ quoteHTML .Doc.Usage }}</pre>
  </section>

  <section>
    <h2>Description</h2>
    <p>{{ quoteHTML .Doc.LongDescription }}</p>
  </section>

  <section>
    <h2>Options</h2>
{{- range .Doc.Groups }}
{{- if .ShortDescription }}
    <h3>{{ quoteHTML .ShortDescription }}</h3>
{{- end }}
    <ul>
{{- range .Options }}
      <li>
{{- $forms := optionForms . -}}
{{- range $idx, $f := $forms -}}
{{- if gt $idx 0 }}, {{ end -}}<code>{{ quoteHTML $f }}</code>
{{- end -}}
{{ defaultValue .Default }}{{ if .Required }} (required){{ end }}
{{- if .Description }} - {{ quoteHTML .Description }}{{ if hiddenMark .Hidden }} <strong>(hidden)</strong>{{ end }}{{ else if hiddenMark .Hidden }} - <strong>(hidden)</strong>{{ end }}
{{- if or .Env .Choices .Optional .IniName .KeyValueDelim .Terminator .DefaultMask .Base .UnquoteTag (ne .Order 0) }}
        <ul>
{{- if .Env }}          <li>env: <code>{{ quoteHTML .Env }}</code>{{ if .EnvDelim }} (delimiter <code>{{ quoteHTML .EnvDelim }}</code>){{ end }}</li>{{ end }}
{{- if .Choices }}      <li>choices: <code>{{ quoteHTML (join .Choices ", ") }}</code></li>{{ end }}
{{- if .Optional }}     <li>optional value: <code>{{ quoteHTML .OptionalVal }}</code></li>{{ end }}
{{- if .IniName }}      <li>ini-name: <code>{{ quoteHTML .IniName }}</code></li>{{ end }}
{{- if .KeyValueDelim }}<li>key-value-delimiter: <code>{{ quoteHTML .KeyValueDelim }}</code></li>{{ end }}
{{- if .Terminator }}   <li>terminator: <code>{{ quoteHTML .Terminator }}</code></li>{{ end }}
{{- if .DefaultMask }}  <li>default-mask: <code>{{ quoteHTML .DefaultMask }}</code></li>{{ end }}
{{- if .Base }}         <li>base: <code>{{ quoteHTML .Base }}</code></li>{{ end }}
{{- if .UnquoteTag }}   <li>unquote: <code>{{ quoteHTML .UnquoteTag }}</code></li>{{ end }}
{{- if ne .Order 0 }}   <li>order: <code>{{ .Order }}</code></li>{{ end }}
        </ul>
{{- end }}
      </li>
{{- end }}
    </ul>
{{- end }}
  </section>

{{- if .Doc.Commands }}
  <section>
    <h2>Commands</h2>
{{- range .Doc.Commands }}
    <article>
      <h3>{{ quoteHTML .Name }}</h3>
      <p>{{ quoteHTML .ShortDescription }}</p>
{{- if .UsageLine }}
      <p><strong>Usage:</strong> <code>{{ quoteHTML .UsageLine }}</code></p>
{{- end }}
{{- if .Aliases }}
      <p><strong>Aliases:</strong> {{ quoteHTML (join .Aliases ", ") }}</p>
{{- end }}
    </article>
{{- end }}
  </section>
{{- end }}
</body>
</html>
