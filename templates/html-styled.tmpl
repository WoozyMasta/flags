<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ quoteHTML .Doc.Name }} {{ i18n "doc.tmpl.html.title.suffix" }}</title>
  <style>
    :root {
      --bg: #f6f7fb;
      --surface: #ffffff;
      --surface-alt: #f0f2f8;
      --text: #0f172a;
      --muted: #475569;
      --border: #dbe2ef;
      --code-bg: #edf2ff;
      --accent: #1d4ed8;
      --ok: #0f766e;
      --warn: #b45309;
      --radius: 14px;
      --shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
      --mono: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas,
        "Liberation Mono", "Courier New", monospace;
      --sans: "Segoe UI", "Inter", -apple-system, BlinkMacSystemFont,
        "Helvetica Neue", Arial, sans-serif;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0b1220;
        --surface: #121b2e;
        --surface-alt: #0f1729;
        --text: #e2e8f0;
        --muted: #9fb2cc;
        --border: #2a3754;
        --code-bg: #1a2740;
        --accent: #60a5fa;
        --ok: #2dd4bf;
        --warn: #f59e0b;
        --shadow: 0 10px 26px rgba(0, 0, 0, 0.35);
      }
    }

    * { box-sizing: border-box; }

    html,
    body {
      background: var(--bg);
    }

    body {
      margin: 0;
      font-family: var(--sans);
      color: var(--text);
      line-height: 1.5;
    }

    main {
      max-width: 1080px;
      margin: 0 auto;
      padding: 24px 16px 48px;
      display: grid;
      gap: 16px;
    }

    .hero {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px 20px;
    }

    h1, h2, h3 {
      margin: 0 0 10px;
      line-height: 1.25;
    }

    h1 { font-size: 1.6rem; }
    h2 { font-size: 1.2rem; }
    h3 { font-size: 1.05rem; color: var(--accent); }
    h2:not(:first-child),
    h3:not(:first-child),
    h4:not(:first-child) {
      margin-top: 16px;
    }

    .muted { color: var(--muted); }

    section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 16px;
    }

    article + article {
      margin-top: 14px;
      padding-top: 10px;
      border-top: 1px dashed var(--border);
    }

    code, pre {
      font-family: var(--mono);
      font-size: 0.92em;
    }

    code {
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.1em 0.35em;
    }

    pre {
      margin: 0;
      overflow: auto;
      background: var(--surface-alt);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 12px;
      white-space: pre-wrap;
    }

    ul { margin: 10px 0 0; padding-left: 18px; }
    li + li { margin-top: 8px; }

    .meta {
      margin-top: 6px;
      color: var(--muted);
      font-size: 0.95em;
    }

    .chip {
      display: inline-block;
      margin-right: 6px;
      margin-bottom: 4px;
      padding: 2px 8px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface-alt);
      color: var(--muted);
      font-size: 0.8rem;
    }

    .chip.required {
      color: var(--ok);
      border-color: color-mix(in srgb, var(--ok) 50%, var(--border));
    }

    .chip.hidden {
      color: var(--warn);
      border-color: color-mix(in srgb, var(--warn) 50%, var(--border));
    }

    a {
      color: var(--accent);
      text-decoration: none;
      text-underline-offset: 2px;
    }

    a:hover {
      text-decoration: underline;
    }

    a:visited {
      color: color-mix(in srgb, var(--accent) 75%, var(--text));
    }

    a:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: 4px;
    }

    .toc ul {
      margin-top: 8px;
    }

    .toc ul ul {
      margin-top: 6px;
    }

    .pre-wrap {
      white-space: pre-wrap;
    }
  </style>
</head>
<body>
  <main>
    <header class="hero">
      <h1>{{ quoteHTML .Doc.Name }}</h1>
      {{- if .Doc.ShortDescription }}
      <p class="muted">{{ quoteHTML .Doc.ShortDescription }}</p>
      {{- end }}
      <pre>{{ quoteHTML .Doc.Name }} {{ quoteHTML .Doc.Usage }}</pre>
    </header>

{{- if .ShowTOC }}
    <section class="toc">
      <h2>Table of Contents</h2>
      <ul>
{{- if .Doc.LongDescription }}
        <li><a href="#description">DESCRIPTION</a></li>
{{- end }}
{{- if .Doc.Groups }}
        <li><a href="#options">OPTIONS</a></li>
{{- end }}
{{- if .Doc.Commands }}
        <li>
          <a href="#commands">COMMANDS</a>
          <ul>
{{- range tocCommandEntries .Doc.Commands }}
            <li><a href="#{{ .Anchor }}">{{ quoteHTML .Name }}</a></li>
{{- end }}
          </ul>
        </li>
{{- end }}
      </ul>
    </section>
{{- end }}

{{- if .Doc.LongDescription }}
    <section>
      <h2 id="description">{{ i18n "doc.tmpl.html.section.description" }}</h2>
      <p class="pre-wrap">{{ quoteHTML .Doc.LongDescription }}</p>
    </section>
{{- end }}

{{- if .Doc.Groups }}
    <section>
      <h2 id="options">{{ i18n "doc.tmpl.html.section.options" }}</h2>
{{- range .Doc.Groups }}
{{- if .ShortDescription }}
      <h3>{{ quoteHTML .ShortDescription }}</h3>
{{- end }}
      <ul>
{{- range .Options }}
        <li>
{{- $forms := optionForms . -}}
{{- range $idx, $f := $forms -}}
{{- if gt $idx 0 }}, {{ end -}}<code>{{ quoteHTML $f }}</code>
{{- end -}}
{{ defaultValue .Default }}
{{- if .Description }} - <span class="pre-wrap">{{ quoteHTML .Description }}</span>{{ end }}
          <div class="meta">
{{- if .Required }}
            <span class="chip required">{{ i18n "doc.tmpl.html.required" }}</span>
{{- end }}
{{- if hiddenMark .Hidden }}
            <span class="chip hidden">{{ i18n "doc.tmpl.html.hidden" }}</span>
{{- end }}
{{- if .Env }}
            <span>{{ i18n "doc.tmpl.html.meta.env" }}</span> <span class="chip">{{ quoteHTML .Env }}</span>
{{- end }}
{{- if .Choices }}
            <span>{{ i18n "doc.tmpl.html.meta.choices" }}</span> <span class="chip">{{ quoteHTML (join .Choices ", ") }}</span>
{{- end }}
{{- if .Optional }}
            <span>{{ i18n "doc.tmpl.html.meta.optional" }}</span> <span class="chip">{{ quoteHTML .OptionalVal }}</span>
{{- end }}
{{- if .IniName }}
            <span>{{ i18n "doc.tmpl.html.meta.ini" }}</span> <span class="chip">{{ quoteHTML .IniName }}</span>
{{- end }}
{{- if .Terminator }}
            <span>{{ i18n "doc.tmpl.html.meta.term" }}</span> <span class="chip">{{ quoteHTML .Terminator }}</span>
{{- end }}
{{- if .KeyValueDelim }}
            <span>{{ i18n "doc.tmpl.html.meta.kv" }}</span> <span class="chip">{{ quoteHTML .KeyValueDelim }}</span>
{{- end }}
{{- if .DefaultMask }}
            <span>{{ i18n "doc.tmpl.html.meta.mask" }}</span> <span class="chip">{{ quoteHTML .DefaultMask }}</span>
{{- end }}
          </div>
        </li>
{{- end }}
      </ul>
{{- end }}
    </section>
{{- end }}

{{- if .Doc.Commands }}
    <section>
      <h2 id="commands">{{ i18n "doc.tmpl.html.section.commands" }}</h2>
{{- if hasNamedCommandGroups .Doc.CommandGroups }}
{{- range .Doc.CommandGroups }}
{{- if .Name }}
      <h3>{{ quoteHTML .Name }}</h3>
{{- end }}
{{- range .Commands }}
{{ template "command" . }}
{{- end }}
{{- end }}
{{- else }}
{{- range .Doc.Commands }}
{{ template "command" . }}
{{- end }}
{{- end }}
    </section>
{{- end }}
  </main>

{{ define "command" }}
      <article>
        <h3 id="{{ tocCommandAnchor .Name }}">{{ quoteHTML .Name }}</h3>
        <p class="pre-wrap">{{ quoteHTML .ShortDescription }}</p>
{{- if .LongDescription }}
        <p class="pre-wrap">{{ quoteHTML .LongDescription }}</p>
{{- end }}
{{- if .UsageLine }}
        <p><strong>{{ i18n "doc.tmpl.html.label.usage" }}:</strong> <code>{{ quoteHTML .UsageLine }}</code></p>
{{- end }}
{{- if .Aliases }}
        <p><strong>{{ i18n "doc.tmpl.html.label.aliases" }}:</strong> {{ quoteHTML (join .Aliases ", ") }}</p>
{{- end }}

{{- range .Groups }}
{{- if .ShortDescription }}
        <h4>{{ quoteHTML .ShortDescription }}</h4>
{{- end }}
        <ul>
{{- range .Options }}
          <li>
{{- $forms := optionForms . -}}
{{- range $idx, $f := $forms -}}
{{- if gt $idx 0 }}, {{ end -}}<code>{{ quoteHTML $f }}</code>
{{- end -}}
{{ defaultValue .Default }}
{{- if .Description }} - <span class="pre-wrap">{{ quoteHTML .Description }}</span>{{ end }}
            <div class="meta">
{{- if .Required }}
              <span class="chip required">{{ i18n "doc.tmpl.html.required" }}</span>
{{- end }}
{{- if hiddenMark .Hidden }}
              <span class="chip hidden">{{ i18n "doc.tmpl.html.hidden" }}</span>
{{- end }}
{{- if .Env }}
              <span>{{ i18n "doc.tmpl.html.meta.env" }}</span> <span class="chip">{{ quoteHTML .Env }}</span>
{{- end }}
{{- if .Choices }}
              <span>{{ i18n "doc.tmpl.html.meta.choices" }}</span> <span class="chip">{{ quoteHTML (join .Choices ", ") }}</span>
{{- end }}
{{- if .Optional }}
              <span>{{ i18n "doc.tmpl.html.meta.optional" }}</span> <span class="chip">{{ quoteHTML .OptionalVal }}</span>
{{- end }}
{{- if .IniName }}
              <span>{{ i18n "doc.tmpl.html.meta.ini" }}</span> <span class="chip">{{ quoteHTML .IniName }}</span>
{{- end }}
{{- if .Terminator }}
              <span>{{ i18n "doc.tmpl.html.meta.term" }}</span> <span class="chip">{{ quoteHTML .Terminator }}</span>
{{- end }}
{{- if .KeyValueDelim }}
              <span>{{ i18n "doc.tmpl.html.meta.kv" }}</span> <span class="chip">{{ quoteHTML .KeyValueDelim }}</span>
{{- end }}
{{- if .DefaultMask }}
              <span>{{ i18n "doc.tmpl.html.meta.mask" }}</span> <span class="chip">{{ quoteHTML .DefaultMask }}</span>
{{- end }}
            </div>
          </li>
{{- end }}
        </ul>
{{- end }}

{{- if .Args }}
        <h4>{{ i18n "doc.tmpl.html.section.arguments" "Arguments" }}</h4>
        <ul>
{{- range .Args }}
          <li><code>{{ quoteHTML .Name }}</code>{{ if .Required }} ({{ i18n "doc.tmpl.html.required" }}){{ end }}{{ if .Description }} - <span class="pre-wrap">{{ quoteHTML .Description }}</span>{{ end }}</li>
{{- end }}
        </ul>
{{- end }}
      </article>
{{- if hasNamedCommandGroups .CommandGroups }}
{{- range .CommandGroups }}
{{- if .Name }}
      <h4>{{ quoteHTML .Name }}</h4>
{{- end }}
{{- range .Commands }}
{{ template "command" . }}
{{- end }}
{{- end }}
{{- else }}
{{- range .Commands }}
{{ template "command" . }}
{{- end }}
{{- end }}
{{ end }}
</body>
</html>
